{% render 'section-css', section_name: 's-social-video-gallery' %}

<section class="bg-white py-16 text-slate-950 sm:py-24">
  <div class="mx-auto max-w-6xl px-6">
    <div class="max-w-3xl">
      {% if section.settings.heading != blank %}
        <h2 class="text-balance text-4xl font-semibold tracking-tight sm:text-6xl">
          {{ section.settings.heading | escape }}
        </h2>
      {% endif %}

      {% if section.settings.description != blank %}
        <p class="mt-5 text-pretty text-lg leading-8 text-slate-600 sm:text-xl">
          {{ section.settings.description | escape | newline_to_br }}
        </p>
      {% endif %}

      {% if section.settings.cta_label != blank and section.settings.cta_url != blank %}
        <div class="mt-8">
          {% render 'c-button',
            label: section.settings.cta_label,
            url: section.settings.cta_url,
            variant: section.settings.cta_variant
          %}
        </div>
      {% endif %}
    </div>

    {% if section.blocks.size > 0 %}
      {% capture marquee_content %}
        {% for block in section.blocks %}
          <div class="aspect-[4/5] w-72 shrink-0 select-none overflow-hidden rounded-3xl bg-slate-100 sm:w-80 lg:w-88" {{ block.shopify_attributes }}>
            {% if block.settings.video != blank %}
              {% render 'c-video',
                video: block.settings.video,
                poster_image: block.settings.poster_image,
                class: 'relative h-full w-full overflow-hidden',
                image_class: 'h-full w-full object-cover',
                video_class: 'absolute inset-0 h-full w-full object-cover'
              %}
            {% elsif block.settings.image != blank %}
              {{ block.settings.image | image_url: width: 1800 | image_tag: class: 'h-full w-full object-cover', loading: 'lazy', draggable: false, widths: '400, 600, 800, 1200, 1800', sizes: '(min-width: 1024px) 25vw, (min-width: 640px) 40vw, 72vw' }}
            {% else %}
              <div class="flex h-full w-full items-center justify-center bg-slate-200 text-4xl text-slate-950">
                <span aria-hidden="true">empty</span>
              </div>
            {% endif %}
          </div>
        {% endfor %}
      {% endcapture %}
      <div class="-mx-6">
        {% render 'c-marquee',
          content: marquee_content,
          stop_on_hover: section.settings.marquee_stop_on_hover,
          speed: section.settings.marquee_speed
        %}
      </div>
    {% endif %}
  </div>
</section>

{% schema %}
{
  "name": "Social video gallery",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Seen, shared, and shopped."
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description",
      "default": "Show off social clips, product moments, and creator content in one clean gallery."
    },
    {
      "type": "text",
      "id": "cta_label",
      "label": "CTA label",
      "default": "Explore more"
    },
    {
      "type": "url",
      "id": "cta_url",
      "label": "CTA link"
    },
    {
      "type": "select",
      "id": "cta_variant",
      "label": "CTA variant",
      "options": [
        {
          "value": "primary",
          "label": "Primary"
        },
        {
          "value": "secondary",
          "label": "Secondary"
        },
        {
          "value": "ghost",
          "label": "Ghost"
        },
        {
          "value": "outline",
          "label": "Outline"
        }
      ],
      "default": "primary"
    },
    {
      "type": "checkbox",
      "id": "marquee_stop_on_hover",
      "label": "Stop marquee on hover",
      "default": true
    },
    {
      "type": "range",
      "id": "marquee_speed",
      "label": "Marquee speed",
      "min": 10,
      "max": 120,
      "step": 5,
      "unit": "px",
      "default": 35
    }
  ],
  "blocks": [
    {
      "type": "media_item",
      "name": "Media item",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "video",
          "id": "video",
          "label": "Video"
        },
        {
          "type": "image_picker",
          "id": "poster_image",
          "label": "Video poster image"
        }
      ]
    }
  ],
  "max_blocks": 12,
  "presets": [
    {
      "name": "Social video gallery",
      "blocks": [
        {
          "type": "media_item"
        },
        {
          "type": "media_item"
        },
        {
          "type": "media_item"
        }
      ]
    }
  ]
}
{% endschema %}
