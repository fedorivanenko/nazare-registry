{% liquid
  assign sg_handle = section.settings.handle
  assign sg_handle_url = section.settings.handle_url
  assign sg_instagram = section.settings.instagram
  assign sg_facebook = section.settings.facebook
  assign sg_youtube = section.settings.youtube
  assign sg_tiktok = section.settings.tiktok
  assign sg_twitter = section.settings.twitter
  assign sg_pinterest = section.settings.pinterest
  assign sg_ratio = section.settings.aspect_ratio | default: 'square'
  assign sg_mode = section.settings.mode | default: 'static'
  assign sg_direction = section.settings.direction | default: 'left'
  assign sg_speed = section.settings.speed | default: 'normal'
  assign sg_pause_on_hover = section.settings.pause_on_hover
  assign sg_rendered = 0

  if sg_pause_on_hover == nil
    assign sg_pause_on_hover = true
  endif

  assign sg_has_header = false
  if sg_handle != blank or sg_instagram != blank or sg_facebook != blank or sg_youtube != blank or sg_tiktok != blank or sg_twitter != blank or sg_pinterest != blank
    assign sg_has_header = true
  endif

  assign ratio_class = 'aspect-square'
  if sg_ratio == 'portrait'
    assign ratio_class = 'aspect-[3/4]'
  elsif sg_ratio == 'landscape'
    assign ratio_class = 'aspect-video'
  endif
%}

{% capture sg_items %}
  {% for block in section.blocks %}
    {% if block.settings.image != blank %}
      {% assign sg_rendered = sg_rendered | plus: 1 %}
      <div data-c-carousel-item {{ block.shopify_attributes }} class="relative shrink-0 {{ ratio_class }} w-64 overflow-hidden">
        <div class="absolute inset-0">
          {% if block.settings.link != blank %}
            <a href="{{ block.settings.link }}" class="absolute inset-0 z-10">
          {% endif %}
          <img
            src="{{ block.settings.image | image_url: width: 600 }}"
            alt="{{ block.settings.alt | default: block.settings.image.alt | escape }}"
            loading="lazy"
            width="{{ block.settings.image.width }}"
            height="{{ block.settings.image.height }}"
            class="size-full object-cover select-none"
          >
          {% if block.settings.link != blank %}
            </a>
          {% endif %}
        </div>
      </div>
    {% endif %}
  {% endfor %}
{% endcapture %}

{% if sg_has_header or sg_rendered > 0 %}
  <section class="bg-background text-foreground">

    {% if sg_has_header %}
      <div class="page-width px-4 lg:px-15 flex items-center justify-between py-8">
        {% if sg_handle != blank %}
        <div class="text-[52px]/[41px] uppercase lg:text-[66px]/[52px] font-heading font-bold tracking-tight">
          {% if sg_handle_url != blank %}
            <a href="{{ sg_handle_url }}" class="hover:opacity-75 transition">{{ sg_handle | escape }}</a>
          {% else %}
            <p>{{ sg_handle | escape }}</p>
          {% endif %}
        </div>
        {% else %}
          <div></div>
        {% endif %}

        {% render 'c-social-links',
          instagram: sg_instagram,
          facebook: sg_facebook,
          youtube: sg_youtube,
          tiktok: sg_tiktok,
          twitter: sg_twitter,
          pinterest: sg_pinterest
        %}
      </div>
    {% endif %}

    {% if sg_rendered > 0 %}
      <div class="pb-12">
        {% render 'c-carousel',
          content: sg_items,
          mode: sg_mode,
          direction: sg_direction,
          speed: sg_speed,
          pause_on_hover: sg_pause_on_hover,
          gap: 'sm'
        %}
      </div>
    {% endif %}

  </section>
{% endif %}

{% schema %}
{
  "name": "Social gallery",
  "settings": [
    {
      "type": "header",
      "content": "Handle"
    },
    {
      "type": "text",
      "id": "handle",
      "label": "Social handle",
      "default": "@yourbrand"
    },
    {
      "type": "url",
      "id": "handle_url",
      "label": "Handle link URL"
    },
    {
      "type": "header",
      "content": "Social links"
    },
    {
      "type": "url",
      "id": "instagram",
      "label": "Instagram URL"
    },
    {
      "type": "url",
      "id": "facebook",
      "label": "Facebook URL"
    },
    {
      "type": "url",
      "id": "youtube",
      "label": "YouTube URL"
    },
    {
      "type": "url",
      "id": "tiktok",
      "label": "TikTok URL"
    },
    {
      "type": "url",
      "id": "twitter",
      "label": "X / Twitter URL"
    },
    {
      "type": "url",
      "id": "pinterest",
      "label": "Pinterest URL"
    },
    {
      "type": "header",
      "content": "Image strip"
    },
    {
      "type": "select",
      "id": "aspect_ratio",
      "label": "Image aspect ratio",
      "default": "square",
      "options": [
        { "value": "square", "label": "Square (1:1)" },
        { "value": "portrait", "label": "Portrait (3:4)" },
        { "value": "landscape", "label": "Landscape (16:9)" }
      ]
    },
    {
      "type": "select",
      "id": "mode",
      "label": "Mode",
      "default": "static",
      "options": [
        { "value": "static", "label": "Static (drag to scroll)" },
        { "value": "marquee", "label": "Marquee (auto-scroll)" }
      ]
    },
    {
      "type": "select",
      "id": "direction",
      "label": "Marquee direction",
      "default": "left",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "right", "label": "Right" }
      ]
    },
    {
      "type": "select",
      "id": "speed",
      "label": "Marquee speed",
      "default": "normal",
      "options": [
        { "value": "slow", "label": "Slow" },
        { "value": "normal", "label": "Normal" },
        { "value": "fast", "label": "Fast" }
      ]
    },
    {
      "type": "checkbox",
      "id": "pause_on_hover",
      "label": "Pause on hover",
      "default": true
    }
  ],
  "blocks": [
    {
      "type": "image",
      "name": "Image",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "text",
          "id": "alt",
          "label": "Alt text"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link URL"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Social gallery",
      "blocks": [
        { "type": "image" },
        { "type": "image" },
        { "type": "image" },
        { "type": "image" },
        { "type": "image" }
      ]
    }
  ]
}
{% endschema %}
