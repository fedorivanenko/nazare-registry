{% doc %}
  Reusable background video with optional poster image.

  @param {video} video - Shopify video object
  @param {image} [poster_image] - Poster/LCP image rendered before video
  @param {string} [class] - Wrapper classes
  @param {string} [image_class] - Poster image classes
  @param {string} [video_class] - Video classes
{% enddoc %}

{% liquid
  assign wrapper_class = class | default: 'relative h-full w-full overflow-hidden'
  assign poster_class = image_class | default: 'h-full w-full object-cover'
  assign player_class = video_class | default: 'absolute inset-0 h-full w-full object-cover'
%}

{% if video != blank or poster_image != blank %}
  <div class="{{ wrapper_class }}">
    {% if poster_image != blank %}
      {{ poster_image | image_url: width: 2400 | image_tag: class: poster_class, loading: 'eager', fetchpriority: 'high', widths: '750, 1100, 1500, 2000, 2400', sizes: '100vw' }}
    {% endif %}

    {% if video != blank %}
      {{ video | video_tag: class: player_class, autoplay: true, loop: true, muted: true, controls: false, playsinline: true, preload: 'metadata' }}
    {% endif %}
  </div>
{% endif %}
