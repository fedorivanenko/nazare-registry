{% doc %}
  Reusable background video with optional poster image.

  @param {video} video - Shopify video object
  @param {image} [poster_image] - Poster/LCP image rendered before video
  @param {string} [class] - Wrapper classes
  @param {string} [image_class] - Poster image classes
  @param {string} [video_class] - Video classes
  @param {boolean} [autoplay] - Autoplay video. Defaults to true.
  @param {boolean} [show_controls] - Show custom play/pause and mute/unmute controls. Defaults to true.
{% enddoc %}

{% liquid
  assign wrapper_class = class | default: 'relative h-full w-full overflow-hidden'
  assign poster_class = image_class | default: 'h-full w-full object-cover'
  assign player_class = video_class | default: 'absolute inset-0 h-full w-full object-cover'
  assign video_autoplay = true
  assign video_show_controls = true

  if autoplay == false
    assign video_autoplay = false
  endif

  if show_controls == false
    assign video_show_controls = false
  endif
%}

{% if video != blank or poster_image != blank %}
  <div class="{{ wrapper_class }}" data-video data-video-autoplay="{{ video_autoplay }}">
    {% if poster_image != blank %}
      {{ poster_image | image_url: width: 2400 | image_tag: class: poster_class, loading: 'eager', fetchpriority: 'high', widths: '750, 1100, 1500, 2000, 2400', sizes: '100vw' }}
    {% endif %}

    {% if video != blank %}
      {{ video | video_tag: class: player_class, autoplay: video_autoplay, loop: true, muted: true, controls: false, playsinline: true, preload: 'metadata' }}

      {% if video_show_controls %}
        <button type="button" class="absolute left-1/2 top-1/2 z-10 flex h-14 w-14 -translate-x-1/2 -translate-y-1/2 items-center justify-center rounded-full bg-black/55 text-white opacity-90 shadow-lg transition hover:bg-black/70 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-white" data-video-play-toggle aria-label="Pause video" aria-pressed="true">
          <span class="sr-only" data-video-play-label>Pause video</span>
          <span class="hidden text-2xl leading-none" data-video-play-icon aria-hidden="true">▶</span>
          <span class="text-2xl leading-none" data-video-pause-icon aria-hidden="true">Ⅱ</span>
        </button>

        <button type="button" class="absolute bottom-4 left-4 z-10 flex h-10 w-10 items-center justify-center rounded-full bg-black/55 text-white opacity-90 shadow-lg transition hover:bg-black/70 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-white" data-video-mute-toggle aria-label="Unmute video" aria-pressed="false">
          <span class="sr-only" data-video-mute-label>Unmute video</span>
          <span class="hidden text-lg leading-none" data-video-mute-icon aria-hidden="true">🔊</span>
          <span class="text-lg leading-none" data-video-unmute-icon aria-hidden="true">🔇</span>
        </button>
      {% endif %}
    {% endif %}
  </div>
{% endif %}
