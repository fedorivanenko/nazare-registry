{% liquid
  assign button_label = label
  assign button_url = url
  assign button_scheme = scheme | default: 'solid'
  assign button_class = class

  unless button_scheme == 'solid' or button_scheme == 'outline' or button_scheme == 'ghost'
    assign button_scheme = 'solid'
  endunless
%}

{% if button_label != blank and button_url != blank %}
  <a
    href="{{ button_url }}"
    class="inline-flex items-center justify-center rounded-full px-5 py-3 text-sm font-semibold transition focus:outline-none focus:ring-2 focus:ring-offset-2 {% if button_scheme == 'outline' %}border border-current bg-transparent text-current hover:bg-current hover:text-background focus:ring-current{% elsif button_scheme == 'ghost' %}bg-transparent text-current underline-offset-4 hover:underline focus:ring-current{% else %}bg-foreground text-background hover:bg-foreground/90 focus:ring-foreground{% endif %}{% if button_class != blank %} {{ button_class }}{% endif %}"
  >
    {{ button_label }}
  </a>
{% endif %}
