{% liquid
  assign hero_eyebrow = section.settings.eyebrow
  assign hero_heading = section.settings.heading
  assign hero_body = section.settings.body
  assign hero_video = section.settings.video
  assign hero_image = section.settings.image
  assign hero_image_alt = section.settings.image_alt
  assign cta_label = section.settings.cta_label
  assign cta_url = section.settings.cta_url
  assign cta_scheme = section.settings.cta_scheme
  assign cta2_label = section.settings.cta2_label
  assign cta2_url = section.settings.cta2_url
  assign hero_badge = section.settings.badge
  assign hero_overlay = section.settings.overlay | default: 'medium'
  assign hero_scheme = section.settings.color_scheme | default: 'dark'
  assign hero_alignment = section.settings.alignment | default: 'left'
  assign hero_heading_size = section.settings.heading_size | default: 'lg'
  assign hero_section_height = section.settings.section_height | default: 'full'
  assign hero_content_vertical = section.settings.content_vertical | default: 'bottom'
  assign hero_layout = section.settings.layout | default: 'stack'

  if hero_image_alt == blank and hero_image.alt != blank
    assign hero_image_alt = hero_image.alt
  endif

  assign text_color_class = 'text-background'
  if hero_scheme == 'light'
    assign text_color_class = 'text-foreground'
  endif

  assign overlay_from = nil
  if hero_overlay == 'light'
    assign overlay_from = 'from-black/30'
  elsif hero_overlay == 'medium'
    assign overlay_from = 'from-black/55'
  elsif hero_overlay == 'dark'
    assign overlay_from = 'from-black/75'
  endif

  case hero_section_height
    when 'banner'
      assign min_height = '280px'
    when 'screen'
      assign min_height = '100dvh'
    else
      assign min_height = 'clamp(560px, 48vw, 700px)'
  endcase

  assign content_vertical_class = 'justify-end'
  if hero_content_vertical == 'center'
    assign content_vertical_class = 'justify-center'
  endif
%}

<section class="relative overflow-hidden bg-black" style="min-height: {{ min_height }}">

  {% if hero_video != blank %}
    <div class="absolute inset-0">
      {% render 'c-bg-video', video: hero_video, poster: hero_image, poster_alt: hero_image_alt, class: 'h-full w-full' %}
    </div>
  {% elsif hero_image != blank %}
    {{ hero_image | image_url: width: 2400 | image_tag: alt: hero_image_alt, loading: 'eager', class: 'absolute inset-0 h-full w-full object-cover' }}
  {% endif %}

  {% if overlay_from != nil %}
    <div class="absolute inset-0 bg-gradient-to-t {{ overlay_from }} to-transparent lg:bg-gradient-to-r"></div>
  {% endif %}

  <div class="relative z-10 flex flex-col {{ content_vertical_class }}" style="min-height: {{ min_height }}">
    <div class="page-width py-[60px]">

      {% if hero_layout == 'split' %}
        <div class="{{ text_color_class }} grid grid-cols-1 items-center gap-8 sm:grid-cols-2">
          <div>
            {% render 'c-heading', text: hero_heading, size: hero_heading_size, tag: 'h1' %}
          </div>
          {% if hero_body != blank %}
            <div class="text-[14px]/[20px] opacity-90 lg:text-[16px]/[20px] [&_a:hover]:underline [&_a]:underline-offset-2">{{ hero_body }}</div>
          {% endif %}
        </div>

      {% elsif hero_alignment == 'center' %}
        <div class="{{ text_color_class }} mx-auto max-w-[540px] text-center">
          {% if hero_eyebrow != blank %}
            <p class="text-xs font-semibold uppercase tracking-widest opacity-75">{{ hero_eyebrow | escape }}</p>
          {% endif %}
          {% render 'c-heading', text: hero_heading, size: hero_heading_size, tag: 'h1', class: 'py-5' %}
          {% if hero_body != blank %}
            <div class="mb-8 text-[14px]/[20px] opacity-90 lg:text-[16px]/[20px] [&_a:hover]:underline [&_a]:underline-offset-2">{{ hero_body }}</div>
          {% endif %}
          {% if cta_label != blank and cta_url != blank or cta2_label != blank and cta2_url != blank %}
            <div class="mt-8 flex flex-col items-stretch gap-4 sm:flex-row sm:items-center" style="{% if hero_scheme == 'light' %}--btn-bg: var(--color-foreground); --btn-text: var(--color-background){% else %}--btn-bg: var(--color-background); --btn-text: var(--color-foreground){% endif %}">
              {% if cta_label != blank and cta_url != blank %}
                {% render 'c-button', label: cta_label, url: cta_url, scheme: cta_scheme %}
              {% endif %}
              {% if cta2_label != blank and cta2_url != blank %}
                <a href="{{ cta2_url }}" class="self-center text-sm font-semibold uppercase tracking-widest underline-offset-4 hover:underline sm:self-auto">{{ cta2_label | escape }}</a>
              {% endif %}
            </div>
          {% endif %}
        </div>

      {% else %}
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 lg:px-15">
          <div class="{{ text_color_class }}">
            {% if hero_eyebrow != blank %}
              <p class="text-xs font-semibold uppercase tracking-widest opacity-75">{{ hero_eyebrow | escape }}</p>
            {% endif %}
            {% render 'c-heading', text: hero_heading, size: hero_heading_size, tag: 'h1', class: 'py-5' %}
            {% if hero_body != blank %}
              <div class="mb-8 text-[14px]/[20px] opacity-90 lg:text-[16px]/[20px] [&_a:hover]:underline [&_a]:underline-offset-2">{{ hero_body }}</div>
            {% endif %}
            {% if cta_label != blank and cta_url != blank or cta2_label != blank and cta2_url != blank %}
              <div class="mt-8 flex flex-col items-stretch gap-4 sm:flex-row sm:items-center" style="{% if hero_scheme == 'light' %}--btn-bg: var(--color-foreground); --btn-text: var(--color-background){% else %}--btn-bg: var(--color-background); --btn-text: var(--color-foreground){% endif %}">
                {% if cta_label != blank and cta_url != blank %}
                  {% render 'c-button', label: cta_label, url: cta_url, scheme: cta_scheme %}
                {% endif %}
                {% if cta2_label != blank and cta2_url != blank %}
                  <a href="{{ cta2_url }}" class="self-center text-sm font-semibold uppercase tracking-widest underline-offset-4 hover:underline sm:self-auto">{{ cta2_label | escape }}</a>
                {% endif %}
              </div>
            {% endif %}
          </div>
        </div>
      {% endif %}

    </div>
  </div>

  {% if hero_badge != blank %}
    <div class="absolute bottom-[60px] right-[60px] z-10 w-40 max-w-[18vw] max-sm:bottom-8 max-sm:right-5 max-sm:w-28 max-sm:max-w-[30vw]">
      {{ hero_badge | image_url: width: 320 | image_tag: alt: '', class: 'block h-auto w-full' }}
    </div>
  {% endif %}

</section>

{% schema %}
{
  "name": "Hero",
  "settings": [
    {
      "type": "header",
      "content": "Background"
    },
    {
      "type": "video",
      "id": "video",
      "label": "Background video"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Background image",
      "info": "Shown as a poster while the video loads, and as a static background when no video is set"
    },
    {
      "type": "text",
      "id": "image_alt",
      "label": "Image alt text"
    },
    {
      "type": "select",
      "id": "overlay",
      "label": "Overlay",
      "default": "medium",
      "options": [
        { "value": "none", "label": "None" },
        { "value": "light", "label": "Light" },
        { "value": "medium", "label": "Medium" },
        { "value": "dark", "label": "Dark" }
      ]
    },
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Hero heading"
    },
    {
      "type": "richtext",
      "id": "body",
      "label": "Body text"
    },
    {
      "type": "header",
      "content": "Primary CTA"
    },
    {
      "type": "url",
      "id": "cta_url",
      "label": "Button URL"
    },
    {
      "type": "text",
      "id": "cta_label",
      "label": "Button label"
    },
    {
      "type": "select",
      "id": "cta_scheme",
      "label": "Button style",
      "default": "solid",
      "options": [
        { "value": "solid", "label": "Solid" },
        { "value": "outline", "label": "Outline" },
        { "value": "ghost", "label": "Ghost" }
      ]
    },
    {
      "type": "header",
      "content": "Secondary CTA"
    },
    {
      "type": "url",
      "id": "cta2_url",
      "label": "Link URL"
    },
    {
      "type": "text",
      "id": "cta2_label",
      "label": "Link label"
    },
    {
      "type": "header",
      "content": "Badge"
    },
    {
      "type": "image_picker",
      "id": "badge",
      "label": "Badge image",
      "info": "Displayed bottom-right. Recommended size: 320×320px."
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "select",
      "id": "section_height",
      "label": "Section height",
      "default": "full",
      "options": [
        { "value": "banner", "label": "Banner" },
        { "value": "full", "label": "Full" },
        { "value": "screen", "label": "Screen" }
      ]
    },
    {
      "type": "select",
      "id": "content_vertical",
      "label": "Vertical alignment",
      "default": "bottom",
      "options": [
        { "value": "bottom", "label": "Bottom" },
        { "value": "center", "label": "Center" }
      ]
    },
    {
      "type": "select",
      "id": "layout",
      "label": "Layout",
      "default": "stack",
      "options": [
        { "value": "stack", "label": "Stack" },
        { "value": "split", "label": "Split" }
      ]
    },
    {
      "type": "select",
      "id": "alignment",
      "label": "Content alignment",
      "default": "left",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "center", "label": "Center" }
      ]
    },
    {
      "type": "select",
      "id": "heading_size",
      "label": "Heading size",
      "default": "lg",
      "options": [
        { "value": "sm", "label": "Small" },
        { "value": "md", "label": "Medium" },
        { "value": "lg", "label": "Large" },
        { "value": "xl", "label": "Extra large" }
      ]
    },
    {
      "type": "select",
      "id": "color_scheme",
      "label": "Text color",
      "default": "dark",
      "options": [
        { "value": "dark", "label": "White" },
        { "value": "light", "label": "Black" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Hero"
    }
  ]
}
{% endschema %}
