{% render 'section-css', section_name: 's-video-gallery' %}

{% liquid
  assign gallery_title = section.settings.title
  assign gallery_description = section.settings.description
  assign cta_label = section.settings.cta_label
  assign cta_url = section.settings.cta_url
  assign cta_scheme = section.settings.cta_scheme
  assign columns = section.settings.columns | default: '3'
  assign layout_mode = section.settings.layout_mode | default: 'grid'
  assign carousel_direction = section.settings.carousel_direction | default: 'left'
  assign carousel_speed = section.settings.carousel_speed | default: 'normal'
  assign carousel_pause_on_hover = section.settings.carousel_pause_on_hover
  assign has_cta = false
  assign rendered_videos = 0

  unless layout_mode == 'grid' or layout_mode == 'carousel' or layout_mode == 'marquee'
    assign layout_mode = 'grid'
  endunless

  if cta_label != blank and cta_url != blank
    assign has_cta = true
  endif
%}

<section class="bg-background text-foreground">
  <div class="page-width py-16 lg:py-24">
    <div class="mb-10 flex flex-col gap-6 lg:mb-14 lg:flex-row lg:items-end lg:justify-between">
      <div class="max-w-3xl">
        {% if gallery_title != blank %}
          <h2 class="text-3xl font-bold tracking-tight sm:text-4xl">{{ gallery_title }}</h2>
        {% endif %}

        {% if gallery_description != blank %}
          <div class="mt-4 text-base leading-7 text-foreground/70 sm:text-lg">
            {{ gallery_description }}
          </div>
        {% endif %}
      </div>

      {% if has_cta %}
        <div class="shrink-0">
          {% render 'c-button', label: cta_label, url: cta_url, scheme: cta_scheme %}
        </div>
      {% endif %}
    </div>

    {% if layout_mode == 'carousel' or layout_mode == 'marquee' %}
      {% capture carousel_items %}
        {% for block in section.blocks %}
          {% if block.settings.video != blank %}
            {% assign rendered_videos = rendered_videos | plus: 1 %}
            <div data-c-carousel-item {{ block.shopify_attributes }} class="h-full shrink-0">
              {% render 'c-video', video: block.settings.video, thumbnail: block.settings.thumbnail, thumbnail_alt: block.settings.thumbnail_alt, id: block.id, class: 'h-full' %}
            </div>
          {% endif %}
        {% endfor %}
      {% endcapture %}

      {% if rendered_videos > 0 %}
        {% liquid
          assign carousel_mode = 'static'
          if layout_mode == 'marquee'
            assign carousel_mode = 'marquee'
          endif
        %}
        {% render 'c-carousel', content: carousel_items, aria_label: gallery_title, mode: carousel_mode, direction: carousel_direction, speed: carousel_speed, pause_on_hover: carousel_pause_on_hover, gap: 'md' %}
      {% endif %}
    {% else %}
      <div class="grid grid-cols-1 gap-6{% if columns == '2' %} lg:grid-cols-2{% elsif columns == '4' %} lg:grid-cols-4{% else %} lg:grid-cols-3{% endif %}">
        {% for block in section.blocks %}
          {% if block.settings.video != blank %}
            {% assign rendered_videos = rendered_videos | plus: 1 %}
            <div {{ block.shopify_attributes }} class="min-w-0">
              {% render 'c-video', video: block.settings.video, thumbnail: block.settings.thumbnail, thumbnail_alt: block.settings.thumbnail_alt, id: block.id %}
            </div>
          {% endif %}
        {% endfor %}
      </div>
    {% endif %}

    {% if rendered_videos == 0 and request.design_mode %}
      <div class="rounded-3xl border border-dashed border-foreground/25 px-6 py-12 text-center text-sm text-foreground/60">
        Add Shopify-hosted video blocks to populate this gallery.
      </div>
    {% endif %}
  </div>
</section>

{% schema %}
{
  "name": "Video gallery",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Title",
      "default": "Watch the collection in motion"
    },
    {
      "type": "richtext",
      "id": "description",
      "label": "Description",
      "default": "<p>Showcase product stories, campaigns, or brand moments with a focused video gallery.</p>"
    },
    {
      "type": "text",
      "id": "cta_label",
      "label": "CTA label"
    },
    {
      "type": "url",
      "id": "cta_url",
      "label": "CTA URL"
    },
    {
      "type": "select",
      "id": "cta_scheme",
      "label": "CTA scheme",
      "default": "solid",
      "options": [
        {
          "value": "solid",
          "label": "Solid"
        },
        {
          "value": "outline",
          "label": "Outline"
        },
        {
          "value": "ghost",
          "label": "Ghost"
        }
      ]
    },
    {
      "type": "select",
      "id": "layout_mode",
      "label": "Layout mode",
      "default": "grid",
      "options": [
        {
          "value": "grid",
          "label": "Grid"
        },
        {
          "value": "carousel",
          "label": "Carousel"
        },
        {
          "value": "marquee",
          "label": "Endless marquee"
        }
      ]
    },
    {
      "type": "select",
      "id": "columns",
      "label": "Columns on large screens",
      "default": "3",
      "options": [
        {
          "value": "2",
          "label": "2 columns"
        },
        {
          "value": "3",
          "label": "3 columns"
        },
        {
          "value": "4",
          "label": "4 columns"
        }
      ]
    },
    {
      "type": "select",
      "id": "carousel_direction",
      "label": "Carousel direction",
      "default": "left",
      "options": [
        {
          "value": "left",
          "label": "Left"
        },
        {
          "value": "right",
          "label": "Right"
        }
      ]
    },
    {
      "type": "select",
      "id": "carousel_speed",
      "label": "Carousel speed",
      "default": "normal",
      "options": [
        {
          "value": "slow",
          "label": "Slow"
        },
        {
          "value": "normal",
          "label": "Normal"
        },
        {
          "value": "fast",
          "label": "Fast"
        }
      ]
    },
    {
      "type": "checkbox",
      "id": "carousel_pause_on_hover",
      "label": "Pause carousel on hover or focus",
      "default": true
    }
  ],
  "blocks": [
    {
      "type": "video",
      "name": "Video",
      "settings": [
        {
          "type": "video",
          "id": "video",
          "label": "Video"
        },
        {
          "type": "image_picker",
          "id": "thumbnail",
          "label": "Thumbnail"
        },
        {
          "type": "text",
          "id": "thumbnail_alt",
          "label": "Thumbnail alt text"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Video gallery",
      "blocks": [
        {
          "type": "video"
        },
        {
          "type": "video"
        },
        {
          "type": "video"
        }
      ]
    }
  ]
}
{% endschema %}
