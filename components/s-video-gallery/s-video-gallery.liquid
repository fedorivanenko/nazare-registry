{% render 'section-css', section_name: 's-video-gallery' %}

{% liquid
  assign gallery_title = section.settings.title
  assign gallery_description = section.settings.description
  assign cta_label = section.settings.cta_label
  assign cta_url = section.settings.cta_url
  assign cta_scheme = section.settings.cta_scheme
  assign vg_mode = section.settings.mode | default: 'static'
  assign vg_direction = section.settings.direction | default: 'left'
  assign vg_speed = section.settings.speed | default: 'normal'
  assign vg_pause_on_hover = section.settings.pause_on_hover
  assign has_cta = false
  assign rendered_videos = 0

  unless vg_mode == 'static' or vg_mode == 'marquee'
    assign vg_mode = 'static'
  endunless

  if vg_pause_on_hover == nil
    assign vg_pause_on_hover = true
  endif

  if cta_label != blank and cta_url != blank
    assign has_cta = true
  endif
%}

<section class="bg-background text-foreground py-16 lg:py-24">
  <div class="px-15">
    <div class="mb-10 flex flex-col gap-6 lg:mb-14 lg:flex-row lg:items-center lg:justify-between">
      <div class="max-w-3xl">
        {% if gallery_title != blank %}
          <h2 class="font-heading text-[52px]/[42px] font-bold uppercase lg:text-[66px]/[52px]">{{ gallery_title | newline_to_br }}</h2>
        {% endif %}

        {% if gallery_description != blank %}
          <div class="mt-3 text-sm text-foreground/70">
            {{ gallery_description }}
          </div>
        {% endif %}
      </div>

      {% if has_cta %}
        <div class="mt-8 sm:mt-0 flex flex-col items-stretch sm:flex-row sm:items-center">
          {% render 'c-button', label: cta_label, url: cta_url, scheme: cta_scheme %}
        </div>
      {% endif %}
    </div>
  </div>

  <div>
    {% capture carousel_items %}
      {% for block in section.blocks %}
        {% if block.settings.video != blank %}
          {% assign rendered_videos = rendered_videos | plus: 1 %}
          <div data-c-carousel-item {{ block.shopify_attributes }} class="h-full shrink-0">
            {% render 'c-video', video: block.settings.video, thumbnail: block.settings.thumbnail, thumbnail_alt: block.settings.thumbnail_alt, id: block.id, class: 'h-full' %}
          </div>
        {% endif %}
      {% endfor %}
    {% endcapture %}

    {% if rendered_videos > 0 %}
      {% render 'c-carousel',
        content: carousel_items,
        aria_label: gallery_title,
        mode: vg_mode,
        direction: vg_direction,
        speed: vg_speed,
        pause_on_hover: vg_pause_on_hover,
        gap: 'sm'
      %}
    {% endif %}

    {% if rendered_videos == 0 and request.design_mode %}
      <div class="mx-15 rounded-xl border border-dashed border-foreground/25 px-6 py-12 text-center text-sm text-foreground/60">
        Add Shopify-hosted video blocks to populate this gallery.
      </div>
    {% endif %}
  </div>
</section>

{% schema %}
{
  "name": "Video gallery",
  "settings": [
    {
      "type": "textarea",
      "id": "title",
      "label": "Title",
      "default": "Watch the collection\nin motion"
    },
    {
      "type": "richtext",
      "id": "description",
      "label": "Description",
      "default": "<p>Showcase product stories, campaigns, or brand moments with a focused video gallery.</p>"
    },
    {
      "type": "text",
      "id": "cta_label",
      "label": "CTA label"
    },
    {
      "type": "url",
      "id": "cta_url",
      "label": "CTA URL"
    },
    {
      "type": "select",
      "id": "cta_scheme",
      "label": "CTA scheme",
      "default": "solid",
      "options": [
        { "value": "solid", "label": "Solid" },
        { "value": "outline", "label": "Outline" },
        { "value": "ghost", "label": "Ghost" }
      ]
    },
    {
      "type": "header",
      "content": "Gallery"
    },
    {
      "type": "select",
      "id": "mode",
      "label": "Mode",
      "default": "static",
      "options": [
        { "value": "static", "label": "Static (drag to scroll)" },
        { "value": "marquee", "label": "Marquee (auto-scroll)" }
      ]
    },
    {
      "type": "select",
      "id": "direction",
      "label": "Marquee direction",
      "default": "left",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "right", "label": "Right" }
      ]
    },
    {
      "type": "select",
      "id": "speed",
      "label": "Marquee speed",
      "default": "normal",
      "options": [
        { "value": "slow", "label": "Slow" },
        { "value": "normal", "label": "Normal" },
        { "value": "fast", "label": "Fast" }
      ]
    },
    {
      "type": "checkbox",
      "id": "pause_on_hover",
      "label": "Pause on hover",
      "default": true
    }
  ],
  "blocks": [
    {
      "type": "video",
      "name": "Video",
      "settings": [
        {
          "type": "video",
          "id": "video",
          "label": "Video"
        },
        {
          "type": "image_picker",
          "id": "thumbnail",
          "label": "Thumbnail"
        },
        {
          "type": "text",
          "id": "thumbnail_alt",
          "label": "Thumbnail alt text"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Video gallery",
      "blocks": [
        { "type": "video" },
        { "type": "video" },
        { "type": "video" }
      ]
    }
  ]
}
{% endschema %}
