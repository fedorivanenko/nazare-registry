{% comment %}nazare:layout footer{% endcomment %}
{% liquid
  assign footer_tagline_image = section.settings.tagline_image
  assign footer_provider = section.settings.email_provider | default: 'none'
  assign footer_list_id = section.settings.klaviyo_list_id
  assign footer_email_heading = section.settings.email_heading
  assign footer_email_description = section.settings.email_description
  assign footer_email_placeholder = section.settings.email_placeholder | default: 'Email Address'
  assign footer_email_button = section.settings.email_button_label | default: 'Sign Up'

  assign nav_menu = section.settings.nav_menu
  assign nav_columns = linklists[nav_menu].links

  assign footer_copyright = section.settings.copyright_text
  assign footer_privacy_label = section.settings.privacy_policy_label | default: 'Privacy Policy'
  assign footer_privacy_url = section.settings.privacy_policy_url
  assign footer_terms_label = section.settings.terms_label | default: 'Terms of Use'
  assign footer_terms_url = section.settings.terms_url
%}

<footer class="bg-background text-foreground mt-15">
  <div class="page-width">

    <div class="grid grid-cols-1 gap-12 lg:grid-cols-2 px-4 lg:px-15">

      <!-- Email signup: first on mobile, right column on desktop -->
      <div class="lg:order-2 lg:col-span-1 lg:pl-12">
        {% if footer_email_heading != blank %}
          <h3 class="text-[14px]/[20px] uppercase font-semibold">{{ footer_email_heading | escape }}</h3>
        {% endif %}

        {% if footer_email_description != blank %}
          <p class="mt-2 text-sm text-foreground/70">{{ footer_email_description | escape }}</p>
        {% endif %}

        {% if footer_provider == 'klaviyo' and footer_list_id != blank %}
          <div class="mt-4">
            {% render 'c-email-signup-klaviyo',
              list_id: footer_list_id,
              placeholder: footer_email_placeholder,
              button_label: footer_email_button
            %}
          </div>
        {% endif %}
      </div>

      <!-- Nav columns: second on mobile (accordion), left column on desktop (grid) -->
      {% if nav_columns.size > 0 %}
        <div class="lg:order-1 lg:col-span-1">
          <div class="lg:grid lg:grid-cols-2 lg:gap-8 xl:grid-cols-4">
            {% for column in nav_columns %}
              {% if column.links.size > 0 %}
                <details class="group border-t border-foreground lg:border-0" open>
                  <summary class="flex cursor-pointer select-none items-center justify-between py-4 text-[14px]/[20px] font-semibold uppercase tracking-widest [&::-webkit-details-marker]:hidden lg:pointer-events-none lg:cursor-default lg:py-0 lg:mb-4">
                    {{ column.title | escape }}
                    <span class="text-[24px]/[24px] font-light transition-transform duration-200 group-open:rotate-45 lg:hidden">+</span>
                  </summary>
                  <ul class="flex flex-col gap-2 pb-4 lg:pb-0">
                    {% for link in column.links %}
                      <li>
                        <a href="{{ link.url }}" class="text-sm text-foreground/70 transition hover:text-foreground">{{ link.title }}</a>
                      </li>
                    {% endfor %}
                  </ul>
                </details>
              {% endif %}
            {% endfor %}
          </div>
        </div>
      {% endif %}
    </div>
  </div>

  {% if footer_tagline_image != blank %}
    <div class="overflow-hidden pt-8 px-4 lg:px-15">
      <img
        src="{{ footer_tagline_image | image_url: width: 2000 }}"
        alt="{{ footer_tagline_image.alt | escape }}"
        width="{{ footer_tagline_image.width }}"
        height="{{ footer_tagline_image.height }}"
        loading="lazy"
        class="mx-auto w-full max-w-none object-contain"
      >
    </div>
  {% endif %}

  {% if footer_copyright != blank or footer_privacy_url != blank or footer_terms_url != blank %}
    <div class="border-t border-foreground/10 py-6">
      <div class="page-width flex flex-wrap items-center justify-between gap-4 text-sm text-foreground/50">
        {% if footer_copyright != blank %}
          <p>{{ footer_copyright | escape }}</p>
        {% endif %}
        <div class="flex gap-6">
          {% if footer_privacy_url != blank %}
            <a href="{{ footer_privacy_url }}" class="transition hover:text-foreground">{{ footer_privacy_label | escape }}</a>
          {% endif %}
          {% if footer_terms_url != blank %}
            <a href="{{ footer_terms_url }}" class="transition hover:text-foreground">{{ footer_terms_label | escape }}</a>
          {% endif %}
        </div>
      </div>
    </div>
  {% endif %}
</footer>

{% schema %}
{
  "name": "Footer",
  "settings": [
    {
      "type": "header",
      "content": "Navigation"
    },
    {
      "type": "link_list",
      "id": "nav_menu",
      "label": "Footer menu",
      "info": "Top-level items become column headings; their child links become the column items."
    },
    {
      "type": "header",
      "content": "Tagline"
    },
    {
      "type": "image_picker",
      "id": "tagline_image",
      "label": "Brand tagline image"
    },
    {
      "type": "header",
      "content": "Email signup"
    },
    {
      "type": "select",
      "id": "email_provider",
      "label": "Email provider",
      "default": "none",
      "options": [
        { "value": "none", "label": "None" },
        { "value": "klaviyo", "label": "Klaviyo" }
      ]
    },
    {
      "type": "text",
      "id": "klaviyo_list_id",
      "label": "Klaviyo list ID",
      "visible_if": "{{ section.settings.email_provider == 'klaviyo' }}"
    },
    {
      "type": "text",
      "id": "email_heading",
      "label": "Email zone heading",
      "default": "Join the newsletter",
      "visible_if": "{{ section.settings.email_provider != 'none' }}"
    },
    {
      "type": "text",
      "id": "email_description",
      "label": "Email zone description",
      "visible_if": "{{ section.settings.email_provider != 'none' }}"
    },
    {
      "type": "text",
      "id": "email_placeholder",
      "label": "Email input placeholder",
      "default": "Email Address",
      "visible_if": "{{ section.settings.email_provider != 'none' }}"
    },
    {
      "type": "text",
      "id": "email_button_label",
      "label": "Email button label",
      "default": "Sign Up",
      "visible_if": "{{ section.settings.email_provider != 'none' }}"
    },
    {
      "type": "header",
      "content": "Legal"
    },
    {
      "type": "text",
      "id": "copyright_text",
      "label": "Copyright text"
    },
    {
      "type": "url",
      "id": "privacy_policy_url",
      "label": "Privacy Policy URL"
    },
    {
      "type": "text",
      "id": "privacy_policy_label",
      "label": "Privacy Policy label",
      "default": "Privacy Policy"
    },
    {
      "type": "url",
      "id": "terms_url",
      "label": "Terms of Use URL"
    },
    {
      "type": "text",
      "id": "terms_label",
      "label": "Terms of Use label",
      "default": "Terms of Use"
    }
  ],
  "presets": [
    {
      "name": "Footer"
    }
  ]
}
{% endschema %}
